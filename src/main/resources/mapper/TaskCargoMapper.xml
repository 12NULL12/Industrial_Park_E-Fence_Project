<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fence.mapper.TaskCargoMapper">

    <resultMap id="BaseResultMap" type="com.fence.entity.TaskCargo">
        <id column="id" property="id"/>
        <result column="task_id" property="taskId"/>
        <result column="cargo_id" property="cargoId"/>
        <result column="cargo_name" property="cargoName"/>
        <result column="weight" property="weight"/>
        <result column="volume" property="volume"/>
        <result column="quantity" property="quantity"/>
        <result column="unit" property="unit"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, task_id, cargo_id, cargo_name, weight, volume, quantity, unit, create_time
    </sql>

    <select id="selectByTaskId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM task_cargo
        WHERE task_id = #{taskId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByCargoId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM task_cargo
        WHERE cargo_id = #{cargoId}
        LIMIT 1
    </select>

    <select id="existsByCargoIdAndTaskId" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM task_cargo
        WHERE cargo_id = #{cargoId}
          AND task_id = #{taskId}
    </select>

    <delete id="deleteByTaskId">
        DELETE FROM task_cargo
        WHERE task_id = #{taskId}
    </delete>

    <delete id="deleteByCargoId">
        DELETE FROM task_cargo
        WHERE cargo_id = #{cargoId}
    </delete>

</mapper>

