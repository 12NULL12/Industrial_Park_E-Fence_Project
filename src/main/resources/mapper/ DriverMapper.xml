<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fence.mapper.DriverMapper">

    <resultMap id="BaseResultMap" type="com.fence.entity.Driver">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="phone" property="phone"/>
        <result column="id_card" property="idCard"/>
        <result column="license_number" property="licenseNumber"/>
        <result column="license_type" property="licenseType"/>
        <result column="license_expiry" property="licenseExpiry"/>
        <result column="age" property="age"/>
        <result column="gender" property="gender"/>
        <result column="status" property="status"/>
        <result column="vehicle_id" property="vehicleId"/>
        <result column="vehicle_plate" property="vehiclePlate"/>
        <result column="current_longitude" property="currentLongitude"/>
        <result column="current_latitude" property="currentLatitude"/>
        <result column="last_online_time" property="lastOnlineTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO driver (
            name, phone, id_card, license_number, license_type,
            license_expiry, age, gender, status,
            create_time, update_time
        ) VALUES (
                     #{name}, #{phone}, #{idCard}, #{licenseNumber}, #{licenseType},
                     #{licenseExpiry}, #{age}, #{gender}, 'AVAILABLE',
                     NOW(), NOW()
                 )
    </insert>

    <update id="update">
        UPDATE driver
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="licenseNumber != null">license_number = #{licenseNumber},</if>
            <if test="licenseType != null">license_type = #{licenseType},</if>
            <if test="licenseExpiry != null">license_expiry = #{licenseExpiry},</if>
            <if test="age != null">age = #{age},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="bindVehicle">
        UPDATE driver
        SET vehicle_id = #{vehicleId},
            vehicle_plate = #{vehiclePlate},
            update_time = NOW()
        WHERE id = #{driverId}
    </update>

    <update id="unbindVehicle">
        UPDATE driver
        SET vehicle_id = NULL,
            vehicle_plate = NULL,
            update_time = NOW()
        WHERE id = #{driverId}
    </update>

    <update id="updateStatus">
        UPDATE driver
        SET status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM driver WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM driver WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT * FROM driver WHERE phone = #{phone}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM driver
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="vehicleId != null">
                AND vehicle_id = #{vehicleId}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM driver
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <select id="selectAvailableDrivers" resultMap="BaseResultMap">
        SELECT * FROM driver
        WHERE status = 'AVAILABLE'
          AND vehicle_id IS NULL
        ORDER BY create_time DESC
            LIMIT 50
    </select>

</mapper>
